#!/usr/bin/env bash
# bstack 설치 진입점. Node 18+ 가 있으면 Ink wizard, 없으면 bash fallback.
set -e

BSTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

has_node18() {
  command -v node >/dev/null 2>&1 || return 1
  node -e "process.exit(parseInt(process.versions.node) >= 18 ? 0 : 1)" >/dev/null 2>&1
}

if has_node18; then
  cd "$BSTACK_DIR/install"
  if [ ! -d node_modules ]; then
    echo "==> Ink wizard 의존성 설치 (최초 1회)"
    if command -v npm >/dev/null 2>&1; then
      npm install --silent --no-audit --no-fund
    else
      echo "    npm 없음 → bash fallback 으로 전환"
      exec "$BSTACK_DIR/setup.sh" "$@"
    fi
  fi
  exec node --import tsx/esm bin/bstack-install.tsx "$@"
else
  echo "==> Node 18+ 없음 → bash fallback (setup.sh)"
  exec "$BSTACK_DIR/setup.sh" "$@"
fi
